# Database Connection
# The Neon standard PostgreSQL connection string
DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# Server Port
PORT=3001

# Optional: List of allowed domains for CORS, separated by commas
# E.g.: https://infra-runner.netlify.app,http://localhost:3000
FRONTEND_URL=https://infra-runner.netlify.app,http://localhost:3000
